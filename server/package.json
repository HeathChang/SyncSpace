{
  "name": "server",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "ts-node-dev --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@socket.io/redis-adapter": "8.3.0",
    "bcrypt": "5.1.1",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cookie": "0.6.0",
    "@types/cookie-parser": "1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "^20.11.0",
    "jest": "29.7.0",
    "prisma": "5.22.0",
    "ts-jest": "29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
